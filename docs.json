{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "IronBee",
  "description": "IronBee documentation — install the CLI, configure your projects, and explore the console.",
  "colors": {
    "primary": "#747c7f",
    "light": "#0a0b0b",
    "dark": "#9fa1a4"
  },
  "favicon": "favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "width": 328
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "directory": "card",
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Introduction",
            "icon": "rocket",
            "pages": [
              "getting-started/introduction",
              "getting-started/quickstart",
              "getting-started/key-concepts"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Setup",
            "icon": "download",
            "pages": [
              "cli/installation",
              "cli/setup",
              "cli/configuration"
            ]
          },
          {
            "group": "Commands",
            "icon": "terminal",
            "pages": [
              "cli/commands",
              "cli/agent-commands"
            ]
          }
        ]
      },
      {
        "tab": "Console",
        "groups": [
          {
            "group": "Projects & Sessions",
            "icon": "layers",
            "pages": [
              "console/projects",
              "console/sessions",
              "console/session-details",
              "console/activities"
            ]
          },
          {
            "group": "Verification & Fixes",
            "icon": "shield-check",
            "pages": [
              "console/verifications",
              "console/verification-detail",
              "console/fixes",
              "console/fix-detail"
            ]
          },
          {
            "group": "Traces & Analysis",
            "icon": "chart-bar",
            "pages": [
              "console/traces",
              "console/analysis",
              "console/findings",
              "console/recommendations"
            ]
          }
        ]
      },
      {
        "tab": "GitHub Action",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "github-action/overview",
              "github-action/getting-started"
            ]
          },
          {
            "group": "Configuration",
            "icon": "settings",
            "pages": [
              "github-action/trigger-modes",
              "github-action/configuration"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://console.ironbee.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/ironbee_ai",
      "linkedin": "https://www.linkedin.com/company/ironbee-ai"
    }
  }
}
